{
  "version": "1",
  "last_updated": "2026-06-25",
  "calculators": [
    {
      "id": "bmi",
      "name": "Body Mass Index",
      "category": "Body Metrics",
      "description": "BMI is a measure of body fat based on height and weight. It is used to screen for weight categories that may lead to health problems.",
      "inputs": [
        { "id": "weightKg", "label": "Weight", "type": "number", "unit": "kg", "required": true },
        { "id": "heightCm", "label": "Height", "type": "number", "unit": "cm", "required": true, "alt_units": [{ "label": "m", "to_base": 100 }] }
      ],
      "results": [
        { "key": "bmi", "label": "BMI", "formula": "weightKg / pow(heightCm / 100, 2)", "unit": "kg/m²", "decimals": 1, "is_primary": true }
      ],
      "transparency_template": "BMI = weight (kg) / (height (m))²\n\n= {weightKg} / ({heightCm} / 100)²\n= {weightKg} / ({heightM})²\n= {weightKg} / {heightMSquared}\n= {bmi} kg/m²",
      "interpretations": [
        { "condition": "value < 18.5", "label": "Underweight", "severity": "warning" },
        { "condition": "value >= 18.5 && value < 25", "label": "Normal Weight", "severity": "normal" },
        { "condition": "value >= 25 && value < 30", "label": "Overweight", "severity": "warning" },
        { "condition": "value >= 30", "label": "Obese", "severity": "high" }
      ]
    },
    {
      "id": "bsa",
      "name": "Body Surface Area",
      "category": "Body Metrics",
      "description": "BSA is used for drug dosing, cardiac output indexing, and fluid resuscitation calculations. Results from both Mosteller and DuBois formulas are provided.",
      "inputs": [
        { "id": "weightKg", "label": "Weight", "type": "number", "unit": "kg", "required": true },
        { "id": "heightCm", "label": "Height", "type": "number", "unit": "cm", "required": true, "alt_units": [{ "label": "m", "to_base": 100 }] }
      ],
      "results": [
        { "key": "mosteller", "label": "BSA (Mosteller)", "formula": "sqrt((heightCm * weightKg) / 3600)", "unit": "m²", "decimals": 2, "is_primary": true },
        { "key": "dubois", "label": "BSA (DuBois)", "formula": "0.007184 * pow(weightKg, 0.425) * pow(heightCm, 0.725)", "unit": "m²", "decimals": 2, "is_primary": false }
      ],
      "transparency_template": "Mosteller: BSA = √(height (cm) × weight (kg) / 3600)\n= √({heightCm} × {weightKg} / 3600)\n= {mosteller} m²\n\nDuBois: BSA = 0.007184 × weight⁰·⁴²⁵ × height⁰·⁷²⁵\n= {dubois} m²"
    },
    {
      "id": "ibw",
      "name": "Ideal Body Weight",
      "category": "Body Metrics",
      "description": "IBW is used for drug dosing calculations, especially for medications with narrow therapeutic windows. Uses the Devine formula.",
      "inputs": [
        { "id": "heightCm", "label": "Height", "type": "number", "unit": "cm", "required": true, "alt_units": [{ "label": "m", "to_base": 100 }] },
        { "id": "isMale", "label": "Sex", "type": "toggle", "options": [{ "label": "Male", "value": true }, { "label": "Female", "value": false }], "default": true }
      ],
      "results": [
        { "key": "ibw", "label": "IBW", "formula": "2.3 * (heightCm / 2.54 - 60) + (isMale ? 50 : 45.5)", "unit": "kg", "decimals": 1, "is_primary": true }
      ],
      "transparency_template": "IBW (Devine) = {genderLabel}:\n= 2.3 × (height (in) − 60) + base\n= 2.3 × ({heightCm} / 2.54 − 60) + {baseWt}\n= {ibw} kg",
      "interpretations": []
    },
    {
      "id": "map",
      "name": "Mean Arterial Pressure",
      "category": "Cardiac",
      "description": "MAP is the average arterial pressure during a single cardiac cycle. It is a key parameter for assessing tissue perfusion.",
      "inputs": [
        { "id": "systolic", "label": "Systolic", "type": "number", "unit": "mmHg", "required": true },
        { "id": "diastolic", "label": "Diastolic", "type": "number", "unit": "mmHg", "required": true }
      ],
      "results": [
        { "key": "map", "label": "MAP", "formula": "diastolic + (systolic - diastolic) / 3", "unit": "mmHg", "decimals": 1, "is_primary": true }
      ],
      "transparency_template": "MAP = Diastolic + (Systolic − Diastolic) / 3\n= {diastolic} + ({systolic} − {diastolic}) / 3\n= {map} mmHg",
      "interpretations": [
        { "condition": "value < 65", "label": "Critical — immediate intervention required", "severity": "high" },
        { "condition": "value >= 65 && value < 70", "label": "Low normal — monitor closely", "severity": "warning" },
        { "condition": "value >= 70 && value <= 100", "label": "Normal", "severity": "normal" },
        { "condition": "value > 100", "label": "Elevated — assess for hypertensive emergency", "severity": "warning" }
      ]
    },
    {
      "id": "qtc",
      "name": "QTc Interval (Corrected QT)",
      "category": "Cardiac",
      "description": "QTc is the QT interval corrected for heart rate. Prolongation increases the risk of Torsades de Pointes. Results from both the Bazett and Fridericia formulas are provided.",
      "inputs": [
        { "id": "qtMs", "label": "QT interval", "type": "number", "unit": "ms", "required": true },
        { "id": "heartRate", "label": "Heart rate", "type": "number", "unit": "bpm", "required": true }
      ],
      "results": [
        { "key": "bazett", "label": "QTc (Bazett)", "formula": "qtMs / sqrt(60 / heartRate)", "unit": "ms", "decimals": 1, "is_primary": true },
        { "key": "fridericia", "label": "QTc (Fridericia)", "formula": "qtMs / pow(60 / heartRate, 1 / 3)", "unit": "ms", "decimals": 1, "is_primary": false }
      ],
      "transparency_template": "RR Interval = 60 / HR = 60 / {heartRate} = {rrInterval} s\n\nBazett: QTc = QT / √RR\n= {qtMs} / √{rrInterval}\n= {bazett} ms\n\nFridericia: QTc = QT / ³√RR\n= {qtMs} / ³√{rrInterval}\n= {fridericia} ms",
      "interpretations": [
        { "condition": "value > 500", "label": "Critically prolonged — high risk of Torsades de Pointes", "severity": "high" },
        { "condition": "value >= 440 && value <= 500", "label": "Borderline prolonged — review QT-prolonging medications", "severity": "warning" },
        { "condition": "value < 440", "label": "Normal", "severity": "normal" }
      ]
    },
    {
      "id": "cardiac_output",
      "name": "Cardiac Output",
      "category": "Cardiac",
      "description": "Cardiac Output (CO) is the volume of blood the heart pumps per minute. Cardiac Index (CI) normalises CO to body surface area.",
      "inputs": [
        { "id": "heartRate", "label": "Heart rate", "type": "number", "unit": "bpm", "required": true },
        { "id": "strokeVolume", "label": "Stroke volume", "type": "number", "unit": "mL", "required": true },
        { "id": "bsa", "label": "BSA (optional)", "type": "number", "unit": "m²", "required": false, "hint": "If known" }
      ],
      "results": [
        { "key": "co", "label": "Cardiac Output", "formula": "heartRate * strokeVolume / 1000", "unit": "L/min", "decimals": 2, "is_primary": true },
        { "key": "ci", "label": "Cardiac Index", "formula": "bsa > 0 ? (heartRate * strokeVolume / 1000) / bsa : 0", "unit": "L/min/m²", "decimals": 2, "is_primary": false }
      ],
      "transparency_template": "CO = HR × SV\n= {heartRate} × {strokeVolume}\n= {co} L/min\n{ciLine}",
      "interpretations": [
        { "condition": "value < 4.0", "label": "Low — assess for cardiogenic shock", "severity": "high" },
        { "condition": "value >= 4.0 && value <= 8.0", "label": "Normal", "severity": "normal" },
        { "condition": "value > 8.0", "label": "Elevated — assess for high-output state", "severity": "warning" }
      ]
    },
    {
      "id": "egfr",
      "name": "eGFR (Cockcroft-Gault)",
      "category": "Renal",
      "description": "Estimates creatinine clearance using the Cockcroft-Gault equation. Used for drug dosing and renal function assessment.",
      "inputs": [
        { "id": "age", "label": "Age", "type": "number", "unit": "yrs", "required": true },
        { "id": "weightKg", "label": "Weight", "type": "number", "unit": "kg", "required": true },
        { "id": "serumCreatinine", "label": "Serum creatinine", "type": "number", "unit": "mg/dL", "required": true },
        { "id": "isFemale", "label": "Sex", "type": "toggle", "options": [{ "label": "Male", "value": false }, { "label": "Female", "value": true }], "default": false }
      ],
      "results": [
        { "key": "egfr", "label": "eGFR", "formula": "((140 - age) * weightKg) / (72 * serumCreatinine) * (isFemale ? 0.85 : 1.0)", "unit": "mL/min", "decimals": 1, "is_primary": true }
      ],
      "transparency_template": "eGFR = ((140 − Age) × Weight) / (72 × Cr) × Sex Factor\n= ((140 − {age}) × {weightKg}) / (72 × {serumCreatinine}) × {sexFactor}\n= {egfr} mL/min",
      "interpretations": [
        { "condition": "value >= 90", "label": "G1 — Normal or high", "severity": "normal" },
        { "condition": "value >= 60 && value < 90", "label": "G2 — Mildly decreased", "severity": "normal" },
        { "condition": "value >= 45 && value < 60", "label": "G3a — Mild to moderately decreased", "severity": "warning" },
        { "condition": "value >= 30 && value < 45", "label": "G3b — Moderate to severely decreased", "severity": "warning" },
        { "condition": "value >= 15 && value < 30", "label": "G4 — Severely decreased", "severity": "high" },
        { "condition": "value < 15", "label": "G5 — Kidney failure", "severity": "high" }
      ]
    },
    {
      "id": "anion_gap",
      "name": "Anion Gap",
      "category": "Renal",
      "description": "The anion gap helps distinguish between different causes of metabolic acidosis. An elevated gap suggests the presence of unmeasured anions.",
      "inputs": [
        { "id": "sodium", "label": "Sodium", "type": "number", "unit": "mEq/L", "required": true },
        { "id": "chloride", "label": "Chloride", "type": "number", "unit": "mEq/L", "required": true },
        { "id": "bicarbonate", "label": "Bicarbonate", "type": "number", "unit": "mEq/L", "required": true }
      ],
      "results": [
        { "key": "ag", "label": "Anion Gap", "formula": "sodium - (chloride + bicarbonate)", "unit": "mEq/L", "decimals": 1, "is_primary": true }
      ],
      "transparency_template": "AG = Na⁺ − (Cl⁻ + HCO₃⁻)\n= {sodium} − ({chloride} + {bicarbonate})\n= {ag} mEq/L",
      "interpretations": [
        { "condition": "value > 12", "label": "Elevated — consider MUDPILES causes", "severity": "warning", "detail": "M — Methanol, U — Uremia, D — DKA, P — Paraldehyde, I — Isoniazid/Infection, L — Lactic acidosis, E — Ethylene glycol, S — Salicylates" },
        { "condition": "value <= 12", "label": "Normal", "severity": "normal" }
      ]
    },
    {
      "id": "fena",
      "name": "FeNa (Fractional Excretion of Sodium)",
      "category": "Renal",
      "description": "FeNa helps differentiate prerenal azotemia from intrinsic renal injury (e.g. acute tubular necrosis).",
      "inputs": [
        { "id": "urineNa", "label": "Urine Na", "type": "number", "unit": "mEq/L", "required": true },
        { "id": "serumCreatinine", "label": "Serum creatinine", "type": "number", "unit": "mg/dL", "required": true },
        { "id": "serumNa", "label": "Serum Na", "type": "number", "unit": "mEq/L", "required": true },
        { "id": "urineCreatinine", "label": "Urine creatinine", "type": "number", "unit": "mg/dL", "required": true }
      ],
      "results": [
        { "key": "fena", "label": "FeNa", "formula": "(urineNa * serumCreatinine) / (serumNa * urineCreatinine) * 100", "unit": "%", "decimals": 2, "is_primary": true }
      ],
      "transparency_template": "FeNa = (UNa × SCr) / (SNa × UCr) × 100%\n= ({urineNa} × {serumCreatinine}) / ({serumNa} × {urineCreatinine}) × 100\n= {fena}%",
      "interpretations": [
        { "condition": "value < 1", "label": "Pre-renal AKI (kidneys conserving sodium)", "severity": "normal" },
        { "condition": "value >= 1 && value <= 2", "label": "Indeterminate — correlate clinically", "severity": "warning" },
        { "condition": "value > 2", "label": "Intrinsic renal injury (ATN likely)", "severity": "high" }
      ]
    },
    {
      "id": "iv_drip_rate",
      "name": "IV Drip Rate",
      "category": "Fluids & Drips",
      "description": "Calculates the IV drip rate in drops per minute based on volume, time, and drop factor of the administration set.",
      "inputs": [
        { "id": "volumeMl", "label": "Volume", "type": "number", "unit": "mL", "required": true },
        { "id": "timeHours", "label": "Time", "type": "number", "unit": "h", "required": true, "hint": "e.g. 1.5" },
        { "id": "dropFactor", "label": "Drop factor", "type": "number", "unit": "gtt/mL", "required": true }
      ],
      "results": [
        { "key": "drip_rate", "label": "Drip rate", "formula": "round((volumeMl * dropFactor) / (timeHours * 60))", "unit": "gtt/min", "decimals": 0, "is_primary": true },
        { "key": "drip_rate_exact", "label": "Drip rate (exact)", "formula": "(volumeMl * dropFactor) / (timeHours * 60)", "unit": "gtt/min", "decimals": 1, "is_primary": false }
      ],
      "transparency_template": "Drip rate = (Volume × Drop Factor) / (Time × 60)\n= ({volumeMl} × {dropFactor}) / ({timeHours} × 60)\n= {drip_rate_exact} ≈ {drip_rate} gtt/min"
    },
    {
      "id": "maintenance_fluid",
      "name": "Maintenance Fluids (4-2-1 Rule)",
      "category": "Fluids & Drips",
      "description": "Calculates maintenance fluid requirements using the Holliday-Segar (4-2-1) rule based on body weight.",
      "inputs": [
        { "id": "weightKg", "label": "Weight", "type": "number", "unit": "kg", "required": true }
      ],
      "results": [
        { "key": "hourly_rate", "label": "Hourly rate", "formula": "weightKg <= 10 ? weightKg * 4 : (weightKg <= 20 ? 40 + (weightKg - 10) * 2 : 60 + (weightKg - 20) * 1)", "unit": "mL/hr", "decimals": 1, "is_primary": true },
        { "key": "daily_rate", "label": "Daily rate", "formula": "(weightKg <= 10 ? weightKg * 4 : (weightKg <= 20 ? 40 + (weightKg - 10) * 2 : 60 + (weightKg - 20) * 1)) * 24", "unit": "mL/day", "decimals": 1, "is_primary": false }
      ],
      "transparency_template": "4-2-1 Rule:\n≤10kg: {tier1} mL/hr\n11-20kg: {tier2} mL/hr\n>20kg: {tier3} mL/hr\n\nHourly: {hourly_rate} mL/hr\nDaily: {hourly_rate} × 24 = {daily_rate} mL/day"
    },
    {
      "id": "parkland",
      "name": "Parkland Formula (Burns)",
      "category": "Fluids & Drips",
      "description": "The Parkland formula estimates fluid resuscitation requirements in the first 24 hours for burn patients.",
      "inputs": [
        { "id": "weightKg", "label": "Weight", "type": "number", "unit": "kg", "required": true },
        { "id": "tbsaPercent", "label": "TBSA", "type": "number", "unit": "%", "required": true }
      ],
      "results": [
        { "key": "total_24hr", "label": "Total 24h fluid", "formula": "4 * weightKg * tbsaPercent", "unit": "mL", "decimals": 1, "is_primary": true },
        { "key": "first_8hr_rate", "label": "First 8h rate", "formula": "(4 * weightKg * tbsaPercent) / 2 / 8", "unit": "mL/hr", "decimals": 1, "is_primary": false },
        { "key": "next_16hr_rate", "label": "Next 16h rate", "formula": "(4 * weightKg * tbsaPercent) / 2 / 16", "unit": "mL/hr", "decimals": 1, "is_primary": false }
      ],
      "transparency_template": "Total 24h = 4 × Weight × TBSA%\n= 4 × {weightKg} × {tbsaPercent}\n= {total_24hr} mL\n\nFirst 8h: Half = {total_24hr} / 2 = {halfTotal} mL\nRate = {halfTotal} / 8 = {first_8hr_rate} mL/hr\n\nNext 16h: Rate = {halfTotal} / 16 = {next_16hr_rate} mL/hr"
    },
    {
      "id": "paed_weight",
      "name": "Weight Estimation by Age",
      "category": "Paediatrics",
      "description": "Estimates weight for children aged 1–12 years using both the APLS and Nelson's formulas.",
      "inputs": [
        { "id": "age", "label": "Age", "type": "number", "unit": "yrs", "required": true }
      ],
      "results": [
        { "key": "nelson", "label": "Weight (Nelson's)", "formula": "age <= 5 ? age * 2 + 8 : 0", "unit": "kg", "decimals": 1, "is_primary": false },
        { "key": "apls", "label": "Weight (APLS)", "formula": "(age + 4) * 2", "unit": "kg", "decimals": 1, "is_primary": false },
        { "key": "recommended", "label": "Recommended", "formula": "age <= 5 ? age * 2 + 8 : (age + 4) * 2", "unit": "kg", "decimals": 1, "is_primary": true }
      ],
      "transparency_template": "Nelson's (≤5 yrs): Weight = (Age × 2) + 8 = ({age} × 2) + 8 = {nelson} kg\nAPLS (>5 yrs): Weight = (Age + 4) × 2 = ({age} + 4) × 2 = {apls} kg\n\nRecommended: {recommended} kg"
    },
    {
      "id": "schwartz",
      "name": "Paediatric eGFR (Schwartz)",
      "category": "Paediatrics",
      "description": "Estimates GFR in children using the Bedside Schwartz equation.",
      "inputs": [
        { "id": "heightCm", "label": "Height", "type": "number", "unit": "cm", "required": true, "alt_units": [{ "label": "m", "to_base": 100 }] },
        { "id": "serumCreatinine", "label": "Serum creatinine", "type": "number", "unit": "mg/dL", "required": true }
      ],
      "results": [
        { "key": "schwartz", "label": "eGFR (Schwartz)", "formula": "0.413 * heightCm / serumCreatinine", "unit": "mL/min/1.73m²", "decimals": 1, "is_primary": true }
      ],
      "transparency_template": "eGFR = 0.413 × Height / Cr\n= 0.413 × {heightCm} / {serumCreatinine}\n= {schwartz} mL/min/1.73m²",
      "interpretations": [
        { "condition": "value >= 90", "label": "G1 — Normal or high", "severity": "normal" },
        { "condition": "value >= 60 && value < 90", "label": "G2 — Mildly decreased", "severity": "normal" },
        { "condition": "value >= 45 && value < 60", "label": "G3a — Mild to moderately decreased", "severity": "warning" },
        { "condition": "value >= 30 && value < 45", "label": "G3b — Moderate to severely decreased", "severity": "warning" },
        { "condition": "value >= 15 && value < 30", "label": "G4 — Severely decreased", "severity": "high" },
        { "condition": "value < 15", "label": "G5 — Kidney failure", "severity": "high" }
      ]
    },
    {
      "id": "paed_dose",
      "name": "Paediatric Drug Dosing",
      "category": "Paediatrics",
      "description": "Calculates paediatric drug doses based on weight, dose per kg, frequency, and optional maximum single dose cap.",
      "inputs": [
        { "id": "doseMgPerKg", "label": "Dose per kg", "type": "number", "unit": "mg/kg", "required": true },
        { "id": "weightKg", "label": "Weight", "type": "number", "unit": "kg", "required": true },
        { "id": "frequencyPerDay", "label": "Dose frequency", "type": "dropdown", "options": [{ "label": "Once daily", "value": 1 }, { "label": "Twice daily", "value": 2 }, { "label": "Three times daily", "value": 3 }, { "label": "Four times daily", "value": 4 }, { "label": "Six times daily", "value": 6 }, { "label": "Eight times daily", "value": 8 }, { "label": "Twelve times daily", "value": 12 }], "default": 1 },
        { "id": "maxSingleDoseMg", "label": "Max single dose (optional)", "type": "number", "unit": "mg", "required": false, "hint": "e.g. 1000" }
      ],
      "results": [
        { "key": "single_dose", "label": "Single dose", "formula": "doseMgPerKg * weightKg", "unit": "mg", "decimals": 1, "is_primary": true },
        { "key": "single_dose_capped", "label": "Single dose (capped)", "formula": "maxSingleDoseMg > 0 && (doseMgPerKg * weightKg) > maxSingleDoseMg ? maxSingleDoseMg : (doseMgPerKg * weightKg)", "unit": "mg", "decimals": 1, "is_primary": false },
        { "key": "daily_total", "label": "Daily total", "formula": "(maxSingleDoseMg > 0 && (doseMgPerKg * weightKg) > maxSingleDoseMg ? maxSingleDoseMg : (doseMgPerKg * weightKg)) * frequencyPerDay", "unit": "mg/day", "decimals": 1, "is_primary": false }
      ],
      "transparency_template": "Single dose = {doseMgPerKg} mg/kg × {weightKg} kg = {single_dose} mg\n{capLine}\nDaily total = {singleDoseDisplay} mg × {frequencyPerDay}/day = {daily_total} mg/day"
    }
  ]
}
